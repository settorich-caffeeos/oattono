# DT Copilot — environment configuration
# Copy this file to `.env.local` and fill in the values.

# --- AI (Claude) ---
# Anthropic API key. When set, DT Copilot uses Claude (claude-opus-4-8) for
# every AI feature. When unset, the app runs in DEMO MODE — all features still
# work and return structured sample content. (Users can also enter their own
# key in-app at /settings.)
ANTHROPIC_API_KEY=

# Optional: override the model (defaults to claude-opus-4-8)
# ANTHROPIC_MODEL=claude-opus-4-8

# --- Auth (Supabase) ---
# Required for the membership system (sign up / login / profile).
# Find these at Supabase Dashboard → Project Settings → API.
# Both are safe to expose to the browser (the anon/publishable key is public).
# When unset, the auth pages show a setup notice and the rest of the app still runs.
NEXT_PUBLIC_SUPABASE_URL=https://aejgpqbaottuzhnzflut.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
